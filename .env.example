# LLM Provider: anthropic | openai | nebius
LLM_PROVIDER=anthropic

# Anthropic API Key (if using anthropic provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (if using openai provider)
OPENAI_API_KEY=your_openai_api_key_here

# Nebius serverless vLLM (if using nebius provider)
NEBIUS_API_KEY=your_nebius_api_key_here
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
# Any model available on your Nebius endpoint, e.g.:
#   meta-llama/Meta-Llama-3.1-70B-Instruct-fast
#   Qwen/Qwen2.5-72B-Instruct
#   mistralai/Mistral-Nemo-Instruct-2407

# Generation parameters
N_PATIENTS=5
ICD10_CODES=I21.0,J18.1
OPCS4_CODES=
OUTPUT_DIR=data/output
MODEL=claude-sonnet-4-6
