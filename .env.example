# LLM Provider: anthropic | openai | nebius
LLM_PROVIDER=anthropic

# Anthropic API Key (if using anthropic provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (if using openai provider)
OPENAI_API_KEY=your_openai_api_key_here

# Nebius serverless vLLM (if using nebius provider)
NEBIUS_API_KEY=your_nebius_api_key_here
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
# Any model available on your Nebius endpoint, e.g.:
#   meta-llama/Meta-Llama-3.1-70B-Instruct-fast
#   Qwen/Qwen2.5-72B-Instruct
#   mistralai/Mistral-Nemo-Instruct-2407

# --- Self-hosted GPU job mode (Dockerfile.gpu + entrypoint.sh) ---
# Runs a local vLLM server on the job's own GPU instead of calling a
# hosted endpoint. NEBIUS_API_KEY/NEBIUS_BASE_URL are set automatically
# by entrypoint.sh in this mode - you only need to set MODEL (and
# optionally the vLLM tuning vars below).
#   MODEL=Qwen/Qwen2.5-7B-Instruct        # must fit the job's GPU preset
#   VLLM_PORT=8000
#   VLLM_GPU_MEM_UTIL=0.90
#   VLLM_STARTUP_TIMEOUT=600               # seconds to wait for model load
#   VLLM_EXTRA_ARGS=--max-model-len 8192   # passed through to vLLM
#   HUGGING_FACE_HUB_TOKEN=your_hf_token   # required for gated models

# Generation parameters
N_PATIENTS=5
OUTPUT_DIR=data/output
MODEL=claude-sonnet-4-6

# Diagnostic/procedure codes driving admission generation. Any coding
# standard registered in src/codes/registry.py can be used via
# DIAGNOSTIC_CODE_SYSTEM / PROCEDURE_CODE_SYSTEM (default: icd10 / opcs4).
DIAGNOSTIC_CODES=I21.0,J18.1
DIAGNOSTIC_CODE_SYSTEM=icd10
PROCEDURE_CODES=
PROCEDURE_CODE_SYSTEM=opcs4
